# Alchemy API key for EVM NFT fetching (Ethereum, Base, Moonbeam).
# Used only on the server (API route). Get one at https://dashboard.alchemy.com/
# Do NOT commit .env or .env.local with real values.
ALCHEMY_ID=your_alchemy_api_key_here

# Optional: Asset Hub WebSocket RPC (default: public dwellir endpoint)
# Only use NEXT_PUBLIC_ if the RPC is public; never expose private/authenticated RPCs.
# NEXT_PUBLIC_ASSET_HUB_WS_URL=wss://polkadot-asset-hub-rpc.dwellir.com
